# GA4 measurement ID (public; shipped in client JS). Optional: omit locally to disable analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-WPD5EEWJTQ

# Newsletter → Google Sheet (Apps Script web app, access: Anyone). Prefer server-only URL:
# NEWSLETTER_SCRIPT_URL=https://script.google.com/macros/s/.../exec
# If unset, NEXT_PUBLIC_NEWSLETTER_SCRIPT_URL is used (URL is visible in the browser bundle).
# Optional: NEXT_PUBLIC_NEWSLETTER_ENABLED=true when only NEWSLETTER_SCRIPT_URL is set (shows form without public script URL).

# Cloudflare Turnstile (optional, reduces bots). Create a widget at dash.cloudflare.com → Turnstile.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...
